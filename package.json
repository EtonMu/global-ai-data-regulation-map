{
  "name": "global-ai-data-regulation-map",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "repository": "https://github.com/EtonMu/global-ai-data-regulation-map",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build:client-corpus": "node scripts/build-client-corpus.mjs",
    "predev": "pnpm run build:client-corpus",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "pnpm run build:client-corpus",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "pnpm run validate:data && pnpm run build && node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "validate:data": "node scripts/validate-data.mjs"
  },
  "dependencies": {
    "country-flag-icons": "^1.6.20",
    "d3-geo": "3.1.1",
    "lucide-react": "^1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/d3-geo": "3.1.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
